# Paxos KV store cluster configuration.
# Read by docker compose (variable substitution) and by the Makefile / scripts.

# Number of nodes to start. Any positive integer; node0 is always the init node.
# docker-compose.yml is regenerated from this value by scripts/gen-compose.sh.
CLUSTER_SIZE=20

# Simulated acceptor and proposer failure rates per Paxos round.
# Set to 0.0 for deterministic tests, 0.1 to exercise the retry / recovery path.
ACCEPT_FAIL=0.1
PROPOSE_FAIL=0.1
